LLM_BASE_URL=https://api.example.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=your_model_name
LLM_MODELS=model_a,model_b,model_c
LLM_CHAT_PATH=/v1/chat/completions
LLM_TIMEOUT_SEC=240
# 流式空回复时回退到非流式的最小预算（秒）。慢/无思维链模型务必保留 60s 以上。
LLM_FALLBACK_MIN_SEC=60
# 标题生成专用模型（轻量便宜的模型，节省 token 与等待时间）；留空则用主模型。
LLM_TITLE_MODEL=model_flash
# 标题单次请求超时（秒）。
LLM_TITLE_TIMEOUT_SEC=20
HOST=127.0.0.1
PORT=8000
MAX_UPLOAD_MB=10